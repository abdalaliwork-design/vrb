# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001

# ─── Discord ────────────────────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# ─── Browser ────────────────────────────────────────────────────────────────
BROWSER_START_URL=https://www.google.com
BROWSER_WIDTH=1280
BROWSER_HEIGHT=720

# ─── Streaming ──────────────────────────────────────────────────────────────
# Frames per second for MJPEG. 15 is a good balance of quality vs CPU.
STREAM_FPS=15

# ─── Session ────────────────────────────────────────────────────────────────
# How long (ms) an empty/idle session lives before cleanup (default: 10 min)
SESSION_IDLE_MS=600000

# ─── Control ────────────────────────────────────────────────────────────────
# Minimum ms between control events per controller (default: 16 ≈ 60fps max)
CONTROL_THROTTLE_MS=16

# ─── CORS ───────────────────────────────────────────────────────────────────
# In dev: Vite dev server. In prod: your Discord activity origin.
CORS_ORIGIN=http://localhost:5173
